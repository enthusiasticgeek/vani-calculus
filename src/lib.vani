    return 0.0;
}

// Polynomial derivative coefficients: d/dx [c0 + c1 x + c2 x² + …]
//                                      = [c1, 2*c2, 3*c3, …]
fn poly_deriv_coeffs(coeffs: Vec<f64>) -> Vec<f64> {
    // TODO: return [i*coeffs[i] for i in 1..n]
    return vec(0.0);
}

// ── Interpolation ─────────────────────────────────────────────────────────────

// Lagrange interpolating polynomial evaluated at x, given n data points.
// O(n²).  Does NOT reimplement f64_lerp (builtin for n=2 linear case).
fn lagrange_interp(xs: Vec<f64>, ys: Vec<f64>, x: f64) -> f64 {
    // TODO: for each j, L_j(x) = prod_{k≠j} (x-xs[k])/(xs[j]-xs[k])
    //       return sum_j ys[j] * L_j(x)
    return 0.0;
}

fn main() -> i64 {
    return 0;
}
